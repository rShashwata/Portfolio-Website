---
// Seamless scrolling strip. Renders the items twice so the GSAP loop
// (in main.js) can translate by -50% forever without a visible seam.
// Scroll velocity also nudges its speed/direction for a kinetic feel.
interface Props {
  items: string[];
  reverse?: boolean;
  accent?: boolean;
}
const { items, reverse = false, accent = false } = Astro.props;
const sep = '✦';
---

<div class:list={['marquee', { 'marquee--accent': accent }]} data-marquee data-reverse={reverse ? 'true' : 'false'}>
  <div class="marquee__track" data-marquee-track>
    {
      [0, 1].map(() => (
        <div class="marquee__group" aria-hidden="true">
          {items.map((item) => (
            <span class="marquee__item">
              {item}
              <span class="marquee__sep">{sep}</span>
            </span>
          ))}
        </div>
      ))
    }
  </div>
</div>

<style>
  .marquee {
    overflow: hidden;
    border-block: 1px solid var(--line);
    padding-block: clamp(0.8rem, 2.5vw, 1.6rem);
    white-space: nowrap;
  }
  .marquee--accent {
    background: var(--accent);
    color: #000;
    border-color: var(--accent);
  }
  .marquee__track {
    display: flex;
    width: max-content;
    will-change: transform;
  }
  .marquee__group {
    display: flex;
    align-items: center;
  }
  .marquee__item {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(1.4rem, 4vw, 3rem);
    letter-spacing: -0.01em;
  }
  .marquee__sep {
    margin-inline: clamp(1rem, 3vw, 2.5rem);
    color: var(--accent-ink);
    font-size: 0.6em;
  }
  .marquee--accent .marquee__sep {
    color: #000;
  }
</style>
