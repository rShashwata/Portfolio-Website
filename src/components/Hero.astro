---
import { profile } from '../data/site.js';
const { roles } = profile;
// Trailing duplicate of the first role makes the vertical rotation loop
// seamlessly (it snaps back to 0 while showing an identical word).
const rotatorWords = [...roles, roles[0]];
---

<section class="hero" id="top" data-hero>
  <div class="hero__grid wrap">
    <div class="hero__text">
      <div class="hero__top">
        <span class="display hero__name" data-split>{profile.name}</span>
      </div>

      <h1 class="hero__role">
        <span class="hero__rotator">
          <span class="hero__rotator-mask">
            <span class="hero__rotator-list" data-rotator-list>
              {rotatorWords.map((r) => <span class="hero__role-word">{r}</span>)}
            </span>
          </span>
          <!-- hand-drawn underline that draws itself in -->
          <svg class="hero__underline" viewBox="0 0 320 24" preserveAspectRatio="none" fill="none" aria-hidden="true">
            <path
              data-draw
              d="M4 15C70 4 110 4 160 13C214 22 250 6 316 11"
              stroke="currentColor"
              stroke-width="4"
              stroke-linecap="round"
            ></path>
          </svg>
        </span>
        <span class="visually-hidden">{profile.name} — {roles.join(', ')}</span>
      </h1>
    </div>
    <div class="hero__portrait" data-halftone role="img" aria-label={`Portrait of ${profile.name}`}>
      <canvas data-halftone-canvas data-src={profile.photo}></canvas>
      <noscript><img src={profile.photo} alt={`Portrait of ${profile.name}`} /></noscript>
    </div>
  </div>

  <a class="hero__scroll" href="#work" data-hero-fade aria-label="Scroll to work">
    <span>Scroll</span>
    <svg width="14" height="40" viewBox="0 0 14 40" fill="none">
      <path d="M7 0V38M7 38L1 32M7 38L13 32" stroke="currentColor" stroke-width="1.4"></path>
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    /* Fill the viewport so the next section's (soft) background never peeks in
       below the fold. The scroll cue is pinned to the hero's bottom, so it
       rides down with the taller container. */
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    /* Lighter top padding + heavier bottom padding lifts the centred name/
       role/portrait block up into the blank space below the nav (it otherwise
       sits low in the tall 100svh hero). The scroll cue is absolutely
       positioned, so it stays pinned near the bottom regardless. */
    padding: clamp(3rem, 7vh, 4.5rem) var(--pad) clamp(4rem, 9vh, 6rem);
  }
  .hero__grid {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 4vh, 3rem);
  }
  .hero__text {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 3vh, 2rem);
  }
  .hero__top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem 1.5rem;
  }
  /* Mobile: portrait sits in flow below the name/role block, centered. On
     desktop (see the 1200px block) it joins a bottom-aligned row beside the
     text. */
  .hero__portrait {
    width: min(68vw, 320px);
    aspect-ratio: 4 / 5; /* overridden to the real image ratio once it decodes */
    align-self: center;
  }
  .hero__portrait canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Name is now a small wordmark, not the focal point — the rotating
     craft below carries the hero so the work feels like the priority. */
  .hero__name {
    font-size: var(--step-1);
    line-height: 1;
  }

  /* Rotating craft — slot-machine vertical scroll through the roles. */
  .hero__role {
    display: flex;
    align-items: flex-end;
  }
  .hero__rotator {
    position: relative;
    display: inline-block;
    /* Set the role font-size HERE so the mask's `em`-based height and the
       underline's `em` offsets resolve against the same size as the words.
       Custom clamp (bigger than the name, but small enough that the longest
       role — "Design Consultant" — never overflows on a phone). */
    font-size: clamp(1.6rem, 0.5rem + 5.5vw, 5.5rem);
  }
  .hero__rotator-mask {
    display: block;
    overflow: hidden;
    height: 1.2em;
    line-height: 1.2;
  }
  .hero__rotator-list {
    display: flex;
    flex-direction: column;
    will-change: transform;
  }
  .hero__role-word {
    display: block;
    height: 1.2em;
    line-height: 1.2;
    white-space: nowrap;
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    font-size: 1em; /* inherit the rotator size set above */
    color: var(--accent-ink);
  }
  .hero__underline {
    position: absolute;
    left: 0;
    bottom: -0.18em;
    width: 100%;
    height: 0.32em;
    color: var(--accent-ink);
    overflow: visible;
  }

  .hero__scroll {
    position: absolute;
    left: 50%;
    bottom: clamp(1.2rem, 4vh, 2.5rem);
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--step--1);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .hero__scroll svg {
    animation: bob 1.8s var(--ease) infinite;
  }
  @keyframes bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }
  /* Bigger rotating craft on desktop (mobile keeps the safe clamp above so
     the longest roles never overflow their nowrap line). */
  @media (min-width: 1024px) {
    .hero__rotator {
      /* Caps at 8rem (was 9rem) so the enlarged portrait always has room
         beside the longest role even on 2560px+ displays. Only bites above
         ~1829px; below that the font is 7vw and unchanged. */
      font-size: clamp(4.5rem, 7vw, 8rem);
    }
  }
  /* Desktop side-by-side: name/role on the left, portrait on the right, in a
     single row whose items are bottom-aligned so the text sits level with the
     base of the portrait. The pair is vertically centred in the hero. The text
     is content-width (the rotating role is never confined, so it can't wrap),
     and space-between pushes the portrait to the .wrap's right edge; the
     longest role still clears it since role + portrait always fit the row.
     Width caps at 520px to guarantee that clearance up to 2560px+. */
  @media (min-width: 1200px) {
    .hero__grid {
      --portrait-w: clamp(360px, 30vw, 520px);
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: clamp(1.5rem, 3vw, 3rem);
    }
    .hero__text {
      flex: none;
    }
    .hero__portrait {
      flex: none;
      width: var(--portrait-w);
      align-self: flex-end;
    }
  }
</style>
